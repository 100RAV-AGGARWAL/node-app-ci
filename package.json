{
  "name": "lilly-scout-be-ts",
  "version": "0.0.0",
  "scripts": {
    "build": "shx rm -rf dist && npm run lint && tsc --project tsconfig.prod.json && npm run build:make-db",
    "build:make-db": "shx mkdir -p dist/repos/common && shx touch dist/repos/common/database.json && echo \"{}\" > dist/repos/common/database.json",
    "clean-install": "shx rm -rf node_modules package-lock.json && npm install",
    "dev:basic": "cross-env DOTENV_CONFIG_PATH=./config/.env.development node --loader ts-node/esm -r dotenv/config ./src/main.ts",
    "dev:watch": "nodemon --exec \"npm run dev:basic\" --watch ./src --ext .ts",
    "dev": "npm run dev:watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit": "lint-staged",
    "prepare": "husky",
    "start": "cross-env DOTENV_CONFIG_PATH=./config/.env.production node -r dotenv/config ./dist/main.js",
    "test": "cross-env NODE_ENV=test vitest",
    "type-check": "tsc -b --noEmit",
    "test:coverage": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=./config/.env.test vitest run --coverage",
    "env:create:dev": "node scripts/create-env-file.mjs development",
    "env:create:test": "node scripts/create-env-file.mjs test",
    "env:create:prod": "node scripts/create-env-file.mjs production"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jet-env": "^1.1.6",
    "jet-logger": "^2.2.3",
    "jet-paths": "^3.1.1",
    "jet-validators": "^2.3.1",
    "jsonfile": "^6.2.1",
    "morgan": "^1.10.1",
    "swagger-ui-express": "^5.0.1",
    "tspo": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@swc/core": "^1.15.33",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonfile": "^6.1.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.2",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "shx": "^0.4.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  },
  "type": "module",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,cjs,mjs}": [
      "prettier --write"
    ]
  }
}